# Database Configuration
DB_HOST=192.168.0.152
DB_PORT=3050
DB_PATH=/var/lib/firebird/3.0/data/aweh_test/dinem.fdb
DB_USER=SYSDBA
DB_PASS=profes

# Firebird Authentication (use correct settings for your server)
# AUTH_PLUGIN: Srp256 (modern) or Legacy_Auth (old installations)
# WIRE_CRYPT: true (encrypted) or false (unencrypted)
AUTH_PLUGIN=Srp256
WIRE_CRYPT=true

# Auto-apply database migrations on startup
# Set to 'true' to run all pending SQL migrations from the migrations/ folder
# Set to 'false' (default) to skip migrations (manual application required)
# Migration state is tracked in RDB$MIGRATIONS table to ensure idempotency
AUTO_MIGRATE=false


# Build metadata
VERSION=1.0.0
BUILD_NUMBER=1
GIT_HASH=unknown
BUILD_DATE=2026-03-07
